{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    // "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "app/components/Projects/dots-boxes/GameBoard.jsx",
    "app/components/ui/text-hover-effect.jsx",
    "app/components/ui/dotted-glow-background.jsx",
    "app/components/ui/canvas-reveal-effect.jsx",
    "app/components/ui/glowing-stars.tsx",
    "app/components/Projects/getCards.js"
  ],
  "exclude": ["node_modules"]
}
